{
  "schemaVersion": 1,
  "id": "vs_clockwork",
  "version": "${version}",
  "name": "Clockwork: Create x Valkyrien Skies",
  "description": "Create VS integration addon",
  "authors": [
    "fluffy",
    "potato"
  ],
  "contributors": [
    "ewoudje",
    "triode",
    "rubydesic"
  ],
  "contact": {
    "homepage": "https://valkyrienskies.org/",
    "sources": "https://github.com/ValkyrienSkies/Clockwork"
  },
  "license": "Apache-2.0",
  "icon": "assets/vs_clockwork/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "org.valkyrienskies.clockwork.fabric.ClockWorkModFabric"
    ],
    "client": [
      "org.valkyrienskies.clockwork.fabric.ClockWorkModFabric${'$'}Client"
    ],
    "preLaunch": [
      "org.valkyrienskies.clockwork.fabric.ValkyrienPreLaunch"
    ],
    "modmenu": [
      "org.valkyrienskies.clockwork.fabric.ClockWorkModFabric${'$'}ModMenu"
    ]
  },
  "mixins": [
    "vs_clockwork-common.mixins.json",
    "vs_clockwork.mixins.json"
  ],
  "depends": {
    "minecraft": ">=1.18.2",
    "valkyrienskies": ">=${vs2_version}"
  }
}
